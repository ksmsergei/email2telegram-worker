{
	"$schema": "node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-05-02",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "src/index.ts",
	"name": "email2telegram-worker",
	"observability": {
		"enabled": true
	},
	"placement": {
		"hostname": "https://api.telegram.org"
	},
	"secrets": {
		"required": [
			"CHAT_ID",
			"BOT_TOKEN"
		]
	},
	"upload_source_maps": true,
	"vars": {
		"API_HOST": "https://api.telegram.org"
	}
}